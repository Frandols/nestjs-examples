{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@events/*": ["src/shared/events/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@topologies/*": ["src/topologies/*"],
      "@app/*": ["src/*"],
      "@billing/*": ["src/modules/billing/*"],
      "@memberships/*": ["src/modules/billing/memberships/*"],
      "@members/*": ["src/modules/billing/members/*"],
      "@payments/*": ["src/modules/billing/payments/*"],
      "@plans/*": ["src/modules/billing/plans/*"]
    }
  }
}
